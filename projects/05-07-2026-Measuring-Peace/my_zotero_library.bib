  author = {Osorio, Javier and Schubiger, Livia I and Weintraub, Michael},
  pages = {78},
  abstract = {Why do some communities engage in armed mobilization in response to disorder and insecurity, while others do not? Can these communities improve local order in the absence of a strong and impartial state? We study the sources of self-defense mobilization (autodefensas) in Mexico and how these groups affect contemporary levels of crime. We argue that historical experiences of armed mobilization can have long-lasting effects on local preferences and institutions, which can facilitate armed collective action and the provision of local order in contexts of rampant insecurity. Our empirical approach traces the sources of recent self-defense groups to the early twentieth century Cristero rebellion and, using an instrumental variables approach, we show that contemporary community mobilization has succeeded in reducing a broad range of crimes.},
  langid = {english},
  file = {/Users/erikh.knudsen/Dropbox/Uni, Gym og skole/Uni statskundskab/10. semester/Literature/Theory_texts/Militias/Vigiliante Mobilization and Local Order- Evidence from Mexico.pdf}
