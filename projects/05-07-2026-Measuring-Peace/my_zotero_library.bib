  title = {The {{Politics}} of {{Non-State Security Provision}} in {{Burkina Faso}}: {{Koglweogo Self-Defence Groups}}’ {{Ambiguous Pursuit}} of {{Recognition}}},
  shorttitle = {The {{Politics}} of {{Non-State Security Provision}} in {{Burkina Faso}}},
  author = {Frowd, Philippe M},
  date = {2022-03-07},
  journaltitle = {African Affairs},
