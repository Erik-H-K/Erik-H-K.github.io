  title = {Mapping the {{Land Cover}} of {{Africa}} at 10 m {{Resolution}} from {{Multi-Source Remote Sensing Data}} with {{Google Earth Engine}}},
  author = {Li, Qingyu and Qiu, Chunping and Ma, Lei and Schmitt, Michael and Zhu, Xiao},
  date = {2020-02-11},
