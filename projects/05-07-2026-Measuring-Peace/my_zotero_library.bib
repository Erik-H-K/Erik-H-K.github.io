  shorttitle = {Protection or Predation?},
  author = {Ibrahim Shire, Mohammed},
  date = {2022-04-03},
  journaltitle = {Small Wars \& Insurgencies},
  shortjournal = {Small Wars \& Insurgencies},
  volume = {33},
