@article{kibrisGeotemporalEvolutionViolence2021,
  title = {The Geo-Temporal Evolution of Violence in Civil Conflicts: {{A}} Micro Analysis of Conflict Diffusion on a New Event Data Set},
  shorttitle = {The Geo-Temporal Evolution of Violence in Civil Conflicts},
