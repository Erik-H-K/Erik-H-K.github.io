  title = {A {{REVIEW OF THE EMPIRICAL LITERATURE ON FARMER COOPERATIVES}}: {{PERFORMANCE}}, {{OWNERSHIP AND GOVERNANCE}}, {{FINANCE}}, {{AND MEMBER ATTITUDE}}: {{A REVIEW OF THE EMPIRICAL LITERATURE ON FARMER COOPERATIVES}}},
