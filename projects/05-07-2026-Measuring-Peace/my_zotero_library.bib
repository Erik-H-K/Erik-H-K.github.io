  title = {T {{{\textsc{HE}}}} {{O}} {{{\textsc{RIGINS}}}} , {{D}} {{{\textsc{EVELOPMENT}}}}{\textsc{, }}{{{\textsc{AND}}}} {{P}} {{{\textsc{OSSIBLE}}}} {{D}} {{{\textsc{ECLINE OF THE}}}} {{M}} {{{\textsc{ODERN}}}} {{S}} {{{\textsc{TATE}}}}},
  shorttitle = {T},
