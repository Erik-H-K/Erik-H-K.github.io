  shorttitle = {States, the Security Sector, and the Monopoly of Violence},
  author = {Carey, Sabine C and Mitchell, Neil J and Lowe, Will},
  date = {2013-03},
  journaltitle = {Journal of Peace Research},
  shortjournal = {Journal of Peace Research},
  volume = {50},
