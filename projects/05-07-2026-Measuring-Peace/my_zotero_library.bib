  urldate = {2022-05-09},
  abstract = {The application of remote sensing to the social sciences is an emerging research area. Recognizing that people’s behavior and values interact with the environment in which they live, analysis of overhead imagery can characterize geographic factors related to economic status, agricultural practice, and access to community resources in a region. Observables associated with economic well being include the presence of commercial infrastructure, house size, presence of vehicles, crop conditions, and access to transportation. The transportation and communication infrastructure also indicates the expected level of interactions among elements of the society. Other important factors may be inferred from indicators derived from the imagery, such as level and types of agricultural production, population density, access to improved roads, distances to schools and businesses, and attributes of communities. Using imagery data collected over rural Afghanistan, we present an initial case study of the direct and indirect indicators derived from the imagery. The methodology for extracting relevant measures from the imagery, through a mix of human-guided and machine learning methods, is demonstrated. We present an initial image-based characterization of villages, describing the levels of economic activity and transportation infrastructure. Plans for extension and validation of these methods are discussed.},
  langid = {english},
  file = {/Users/erikh.knudsen/Dropbox/Uni, Gym og skole/Uni statskundskab/10. semester/Literature/Methode_texts/satellit/CHARACTERIZATION OF VILLAGES IN RURAL AFGHANISTAN.pdf}
}

@article{irvineViewingSocietySpace2017,
