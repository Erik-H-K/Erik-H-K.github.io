  shorttitle = {Coping with {{Asymmetries}} in the {{Commons}}},
  author = {Ostrom, Elinor and Gardner, Roy},
  date = {1993-11-01},
  journaltitle = {Journal of Economic Perspectives},
  shortjournal = {Journal of Economic Perspectives},
  volume = {7},
