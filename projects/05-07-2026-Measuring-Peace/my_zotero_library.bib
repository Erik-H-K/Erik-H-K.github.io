@article{arjonaCivilianCooperationNonCooperation2017,
  title = {Civilian {{Cooperation}} and {{Non-Cooperation}} with {{Non-State Armed Groups}}: {{The Centrality}} of {{Obedience}} and {{Resistance}}},
